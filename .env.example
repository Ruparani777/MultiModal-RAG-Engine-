# ─────────────────────────────────────────────
#  MultiModal RAG Engine — Environment Config
# ─────────────────────────────────────────────

# LLM Provider (choose one or both)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model Configuration
LLM_PROVIDER=openai                          # "openai" or "anthropic"
LLM_MODEL=gpt-4o                             # gpt-4o | claude-sonnet-4-20250514
VISION_MODEL=gpt-4o                          # gpt-4o | claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small       # OpenAI embedding model
EMBEDDING_DIMENSION=1536

# Vector Store
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=multimodal_rag

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_IMAGE_SIZE_MB=20

# Retrieval
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
